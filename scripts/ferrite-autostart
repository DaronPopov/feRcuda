#!/usr/bin/env python3
"""
ferrite-autostart -- Boot-time Claude Code remote session launcher.

Vendored from the local ferrite-mcp workspace so feRcuda can install the
remote-access flow without depending on a separate checkout at runtime.
"""

import os
import re
import sys
import ssl
import time
import uuid
import fcntl
import signal
import smtplib
import subprocess
import logging
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart
from pathlib import Path

CLAUDE_BIN = Path(os.environ.get("CLAUDE_BIN", Path.home() / ".local/bin/claude"))
HOME = Path.home()
CONFIG_FILE = HOME / ".config/ferrite/env"
URL_FILE = HOME / ".local/share/ferrite/remote-session-url.txt"
LOG_FILE = HOME / ".local/share/ferrite/autostart.log"
LOCK_FILE = HOME / ".local/share/ferrite/autostart.lock"
NOTIFY_STATE = HOME / ".local/share/ferrite/autostart-notify.state"


def load_env(path: Path) -> dict:
    env = {}
    if not path.exists():
        return env
    for line in path.read_text().splitlines():
        line = line.strip()
        if line and not line.startswith("#") and "=" in line:
            k, _, v = line.partition("=")
            env[k.strip()] = v.strip()
    return env


cfg = load_env(CONFIG_FILE)
gmail_cfg = load_env(HOME / ".config/ferrite/gmail.conf")
NTFY_TOPIC = os.environ.get("NTFY_TOPIC", cfg.get("NTFY_TOPIC", ""))
SESSION = os.environ.get("FERRITE_SESSION", cfg.get("FERRITE_SESSION", "claude-remote"))
READY_TIMEOUT = int(os.environ.get("FERRITE_READY_TIMEOUT", cfg.get("FERRITE_READY_TIMEOUT", "90")))
URL_TIMEOUT = int(os.environ.get("FERRITE_URL_TIMEOUT", cfg.get("FERRITE_URL_TIMEOUT", "30")))
WATCHDOG = os.environ.get("FERRITE_WATCHDOG", "1") == "1"
REPLACE_SESSION = os.environ.get("FERRITE_REPLACE_SESSION", cfg.get("FERRITE_REPLACE_SESSION", "0")) == "1"
EMAIL_COOLDOWN_SECS = int(
    os.environ.get("FERRITE_EMAIL_COOLDOWN", cfg.get("FERRITE_EMAIL_COOLDOWN", "900"))
)
GMAIL_USER = gmail_cfg.get("GMAIL_USER", "")
GMAIL_PASS = gmail_cfg.get("GMAIL_APP_PASSWORD", "")
GMAIL_TO = gmail_cfg.get("GMAIL_TO", GMAIL_USER)

LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s  %(levelname)-7s  %(message)s",
    datefmt="%Y-%m-%d %H:%M:%S",
    handlers=[
        logging.FileHandler(LOG_FILE),
        logging.StreamHandler(sys.stdout),
    ],
)
log = logging.getLogger("ferrite-autostart")


def _read_notify_state() -> tuple[float, str]:
    try:
        raw = NOTIFY_STATE.read_text().strip().split("\t", 1)
        ts = float(raw[0]) if raw and raw[0] else 0.0
        url = raw[1].strip() if len(raw) > 1 else ""
        return ts, url
    except Exception:
        return 0.0, ""


def _write_notify_state(ts: float, url: str):
    NOTIFY_STATE.parent.mkdir(parents=True, exist_ok=True)
    NOTIFY_STATE.write_text(f"{ts}\t{url}\n")


def _should_send_email(url: str) -> tuple[bool, str]:
    if not url:
        return False, "no_url"
    now = time.time()
    last_ts, last_url = _read_notify_state()
    if last_url and url == last_url:
        return False, "duplicate_url"
    if now - last_ts < EMAIL_COOLDOWN_SECS:
        return False, f"cooldown:{int(EMAIL_COOLDOWN_SECS - (now - last_ts))}s"
    return True, "ok"


def notify(title: str, body: str, url: str = "", tags: str = "tada,laptop", priority: str = "high", email: bool = True):
    try:
        subprocess.run(
            ["notify-send", "-t", "15000", "-i", "dialog-information", title, body],
            capture_output=True,
            timeout=5,
        )
    except Exception:
        pass

    if email and GMAIL_USER and GMAIL_PASS:
        allowed, reason = _should_send_email(url)
        if allowed:
            if _send_gmail(title, body, url):
                _write_notify_state(time.time(), url)
        else:
            log.info(f"email suppressed ({reason})")

    if NTFY_TOPIC:
        full_body = f"{body}\n{url}" if url else body
        try:
            subprocess.run(
                [
                    "curl",
                    "-sf",
                    "-H",
                    f"Title: {title}",
                    "-H",
                    f"Tags: {tags}",
                    "-H",
                    f"Priority: {priority}",
                    "-d",
                    full_body,
                    f"https://ntfy.sh/{NTFY_TOPIC}",
                ],
                capture_output=True,
                timeout=10,
            )
            log.info(f"ntfy sent to topic '{NTFY_TOPIC}'")
        except Exception as e:
            log.warning(f"ntfy failed: {e}")


def _send_gmail(subject: str, body: str, url: str = "") -> bool:
    try:
        link_html = (
            f'<p><a href="{url}" style="background:#5046e4;color:white;'
            f'padding:12px 24px;border-radius:6px;text-decoration:none;font-weight:bold">'
            f"Open Claude Session -></a></p>"
        ) if url else ""
        html_body = f"""
<html><body style="font-family:sans-serif;max-width:600px;margin:40px auto">
  <h2 style="color:#1a1a2e">Session Ready</h2>
  <p>{body}</p>
  {link_html}
  <hr style="border:none;border-top:1px solid #eee;margin:24px 0">
  <p style="color:#999;font-size:11px">Sent by ferrite-autostart</p>
</body></html>
"""
        msg = MIMEMultipart("alternative")
        msg["Subject"] = subject
        msg["From"] = f"ferrite <{GMAIL_USER}>"
        msg["To"] = GMAIL_TO
        msg.attach(MIMEText(body, "plain"))
        msg.attach(MIMEText(html_body, "html"))

        ctx = ssl.create_default_context()
        with smtplib.SMTP("smtp.gmail.com", 587) as server:
            server.ehlo()
            server.starttls(context=ctx)
            server.login(GMAIL_USER, GMAIL_PASS)
            server.sendmail(GMAIL_USER, GMAIL_TO, msg.as_string())
        log.info(f"email sent to {GMAIL_TO}")
        return True
    except smtplib.SMTPAuthenticationError:
        log.error("Gmail auth failed; check GMAIL_APP_PASSWORD in ~/.config/ferrite/gmail.conf")
    except Exception as e:
        log.warning(f"Gmail send failed: {e}")
    return False


def tmux(*args) -> subprocess.CompletedProcess:
    return subprocess.run(["tmux"] + list(args), capture_output=True, text=True)


def session_alive() -> bool:
    return tmux("has-session", "-t", SESSION).returncode == 0


def kill_session():
    tmux("kill-session", "-t", SESSION)


def start_session() -> bool:
    env = os.environ.copy()
    env.setdefault("HOME", str(HOME))
    fresh_id = str(uuid.uuid4())
    result = subprocess.run(
        [
            "tmux",
            "new-session",
            "-d",
            "-s",
            SESSION,
            "-x",
            "220",
            "-y",
            "50",
            "--",
            str(CLAUDE_BIN),
            "--dangerously-skip-permissions",
            "--session-id",
            fresh_id,
        ],
        env=env,
        capture_output=True,
    )
    if result.returncode != 0:
        log.error(f"tmux new-session failed: {result.stderr.strip()}")
        return False
    log.info(f"tmux session '{SESSION}' created with claude")
    return True


def pane_content(lines: int = 200) -> str:
    r = tmux("capture-pane", "-t", f"{SESSION}:0.0", "-p", "-J", "-S", f"-{lines}")
    return r.stdout


def send_keys(keys: str, enter: bool = True):
    args = ["send-keys", "-t", SESSION, keys]
    if enter:
        args.append("Enter")
    tmux(*args)


_ANSI = re.compile(r"\x1b(?:\[[0-9;]*[mGKHFABCDJPST]|\][^\x07]*\x07|[()][AB012])")
_URL_RE = re.compile(r"https://claude\.ai/\S{8,}")


def strip_ansi(text: str) -> str:
    return _ANSI.sub("", text).replace("\r", "")


def extract_urls(raw: str) -> list[str]:
    clean = strip_ansi(raw)
    matches = _URL_RE.findall(clean)
    urls: list[str] = []
    for match in matches:
        url = match.rstrip(".,)\"'")
        if len(url) > 30 and url not in urls:
            urls.append(url)
    return urls


def save_url(url: str):
    URL_FILE.parent.mkdir(parents=True, exist_ok=True)
    URL_FILE.write_text(url + "\n")
    log.info(f"URL saved to {URL_FILE}")


def clear_saved_url():
    try:
        URL_FILE.unlink(missing_ok=True)
    except Exception:
        pass


READY_PATTERNS = [
    "? for shortcuts",
    "How can I help",
    "What would you like",
]
READY_FALLBACKS = ["\u276f", "> "]


def wait_for_ready(timeout: int) -> bool:
    log.info(f"waiting up to {timeout}s for claude to become interactive...")
    deadline = time.time() + timeout
    while time.time() < deadline:
        if not session_alive():
            log.error("tmux session died while waiting for claude")
            return False
        content = strip_ansi(pane_content(50))
        if any(pattern in content for pattern in READY_PATTERNS):
            log.info("claude is interactive (primary pattern matched)")
            time.sleep(2)
            return True
        elapsed = timeout - (deadline - time.time())
        if elapsed > 30 and any(pattern in content for pattern in READY_FALLBACKS):
            log.info("claude is interactive (fallback pattern matched)")
            time.sleep(2)
            return True
        time.sleep(1.5)
    log.warning("ready timeout reached; proceeding anyway")
    return False


def enable_remote_control() -> str | None:
    baseline_urls = set(extract_urls(pane_content(600)))
    for attempt in range(1, 3):
        log.info(f"sending /remote-control (attempt {attempt})")
        tmux("clear-history", "-t", f"{SESSION}:0.0")
        send_keys("/remote-control", enter=False)
        time.sleep(3)
        log.info("confirming command with Enter")
        send_keys("", enter=True)
        time.sleep(2)
        log.info(f"waiting up to {URL_TIMEOUT}s for session URL...")
        deadline = time.time() + URL_TIMEOUT
        while time.time() < deadline:
            content = pane_content(600)
            urls = extract_urls(content)
            fresh = [url for url in urls if url not in baseline_urls]
            if fresh:
                url = fresh[-1]
                log.info(f"captured URL: {url}")
                return url
            time.sleep(0.75)
        log.warning(f"URL not captured on attempt {attempt}")
    log.warning("URL not captured after all attempts")
    return None


def run_boot_sequence(from_watchdog: bool = False) -> bool:
    if session_alive():
        if REPLACE_SESSION:
            log.info(f"session '{SESSION}' already running; replacing by config")
            clear_saved_url()
            kill_session()
            time.sleep(1)
        else:
            log.info(f"session '{SESSION}' already running; reusing existing session")
            wait_for_ready(min(READY_TIMEOUT, 30))
            url = enable_remote_control()
            if url:
                save_url(url)
                notify(
                    "Claude Ready",
                    "Remote session live; tap link to open",
                    url=url,
                    tags="tada,laptop",
                    priority="high",
                    email=not from_watchdog,
                )
                log.info("boot sequence complete")
                return True
            notify(
                "Claude Session Running",
                f"tmux session '{SESSION}' is active, but URL capture failed. Attach: tmux attach -t {SESSION}",
                tags="laptop",
                priority="default",
                email=False,
            )
            log.warning("boot sequence complete (URL not captured)")
            return True

    if not start_session():
        notify("ferrite FAIL", "Failed to start claude session", tags="x,laptop", priority="urgent", email=not from_watchdog)
        return False
    clear_saved_url()
    time.sleep(4)
    wait_for_ready(READY_TIMEOUT)
    if not session_alive():
        notify("ferrite FAIL", "Claude session exited during startup", tags="x,laptop", priority="urgent", email=False)
        return False

    url = enable_remote_control()
    if url:
        save_url(url)
        notify(
            "Claude Ready",
            "Remote session live; tap link to open",
            url=url,
            tags="tada,laptop",
            priority="high",
            email=not from_watchdog,
        )
        log.info("boot sequence complete")
        return True

    notify(
        "Claude Session Started",
        f"tmux session '{SESSION}' running. Open terminal -> tmux attach -t {SESSION}",
        tags="laptop",
        priority="default",
        email=False,
    )
    log.warning("boot sequence complete (URL not captured)")
    return True


_running = True


def _sigterm(signum, frame):
    del signum, frame
    global _running
    log.info("received SIGTERM; shutting down")
    _running = False


def watchdog_loop():
    signal.signal(signal.SIGTERM, _sigterm)
    log.info("watchdog active; will restart session if it dies")
    while _running:
        time.sleep(30)
        if not _running:
            break
        if not session_alive():
            log.warning("session died; restarting...")
            notify(
                "ferrite WARN",
                "Claude session died; restarting...",
                tags="warning,laptop",
                priority="default",
                email=False,
            )
            time.sleep(5)
            run_boot_sequence(from_watchdog=True)


if __name__ == "__main__":
    LOCK_FILE.parent.mkdir(parents=True, exist_ok=True)
    _lock_fd = open(LOCK_FILE, "w")
    try:
        fcntl.flock(_lock_fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        sys.exit(0)

    log.info("=" * 60)
    log.info("ferrite-autostart starting")
    log.info(f"  claude    : {CLAUDE_BIN}")
    log.info(f"  session   : {SESSION}")
    log.info(f"  gmail     : {'configured' if GMAIL_USER else 'NOT SET'}")
    log.info(f"  ntfy      : {'configured' if NTFY_TOPIC else 'not set'}")
    log.info(f"  watchdog  : {WATCHDOG}")
    log.info(f"  replace   : {REPLACE_SESSION}")

    if not CLAUDE_BIN.exists():
        log.error(f"claude binary not found at {CLAUDE_BIN}")
        notify("ferrite FAIL", f"claude not found at {CLAUDE_BIN}", tags="x", priority="urgent")
        sys.exit(1)

    ok = run_boot_sequence()
    if not ok:
        sys.exit(1)

    if WATCHDOG:
        watchdog_loop()
